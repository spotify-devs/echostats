# ──────────────────────────────────────────────────────────────────────────────
# EchoStats — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ── Spotify API ──────────────────────────────────────────────────────────────
# Create your app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://echostats:changeme@mongodb:27017/echostats?authSource=admin
MONGO_DB=echostats
MONGO_USER=echostats
MONGO_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret
ENCRYPTION_KEY=change_this_to_a_64_char_hex_string

# ── Web Frontend ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000

# ── Background Worker ────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=15
ANALYTICS_REFRESH_HOURS=6

# ── Umami Telemetry (optional) ───────────────────────────────────────────────
UMAMI_URL=
UMAMI_WEBSITE_ID=

# ── Docker ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=echostats
